# ──────────────────────────────────────────────────────────
#  RiskLab · USTA  —  Variables de entorno
#  Copia este archivo como .env y rellena los valores reales.
#  NUNCA subas .env a Git (está en .gitignore).
# ──────────────────────────────────────────────────────────

# Claves de APIs externas (opcionales; mejoran la calidad de datos)
ALPHA_VANTAGE_KEY=your_alpha_vantage_key_here
FRED_API_KEY=your_fred_api_key_here
FINNHUB_KEY=your_finnhub_key_here

# Portafolio por defecto
DEFAULT_TICKERS=["AAPL","JPM","XOM","JNJ","AMZN"]
BENCHMARK=^GSPC
DEFAULT_YEARS=3

# Parámetros de modelos
VAR_CONFIDENCE_DEFAULT=0.95
MC_SIMULATIONS=10000
RF_FALLBACK=0.0525

# Indicadores técnicos
SMA_SHORT=20
SMA_LONG=50
EMA_PERIOD=20
RSI_PERIOD=14
MACD_FAST=12
MACD_SLOW=26
MACD_SIGNAL=9
BB_PERIOD=20
BB_STD=2.0
STOCH_K=14
STOCH_D=3
