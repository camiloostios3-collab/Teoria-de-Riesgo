# ──────────────────────────────────────────────────────────
#  RiskLab · USTA  —  Variables de entorno
#  Copia este archivo como .env y rellena los valores reales.
#  NUNCA subas .env a Git (está en .gitignore).
# ──────────────────────────────────────────────────────────

# ── APIs externas ──────────────────────────────────────────────────────────────
# FRED   → https://fred.stlouisfed.org/docs/api/api_key.html  (gratuita)
# Alpha  → https://www.alphavantage.co/support/#api-key       (gratuita, 25 req/día)
# Finnhub → https://finnhub.io/register                       (gratuita)
ALPHA_VANTAGE_KEY=your_alpha_vantage_key_here
FRED_API_KEY=your_fred_api_key_here
FINNHUB_KEY=your_finnhub_key_here

# ── Base de datos ───────────────────────────────────────────────────────────────
# SQLite local (desarrollo):
DATABASE_URL=sqlite:///./risklab.db
# SQLite dentro de Docker (el volumen lo persiste):
# DATABASE_URL=sqlite:////app/data/risklab.db

# ── CORS (producción) ───────────────────────────────────────────────────────────
# Lista de orígenes del frontend. En desarrollo puedes dejar ["*"].
# En producción reemplaza con la URL real, por ejemplo:
# ALLOWED_ORIGINS=["https://mi-frontend.onrender.com"]
ALLOWED_ORIGINS=["*"]

# ── Portafolio por defecto ──────────────────────────────────────────────────────
DEFAULT_TICKERS=["AAPL","JPM","XOM","JNJ","AMZN"]
BENCHMARK=^GSPC
DEFAULT_YEARS=3

# ── Parámetros de modelos ───────────────────────────────────────────────────────
VAR_CONFIDENCE_DEFAULT=0.95
MC_SIMULATIONS=10000
RF_FALLBACK=0.0525

# ── Indicadores técnicos ────────────────────────────────────────────────────────
SMA_SHORT=20
SMA_LONG=50
EMA_PERIOD=20
RSI_PERIOD=14
MACD_FAST=12
MACD_SLOW=26
MACD_SIGNAL=9
BB_PERIOD=20
BB_STD=2.0
STOCH_K=14
STOCH_D=3
